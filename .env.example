# Code Audit — API Keys
# Priority: NVIDIA (primary) → Gemini (fallback 1) → OpenRouter (fallback 2)
#
# Copy this to .env and fill in your keys.
# Or symlink to your central .env: ln -s ../../.env .env

# Primary: NVIDIA Build (free developer tier, 30 RPM, 5000 RPD)
# Get key at: https://build.nvidia.com/
NVIDIA_API_KEY=

# Fallback 1: Google Gemini (free tier, 1400 RPD)
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Fallback 2: OpenRouter (free models, 1000 RPD with $10 credit)
# Get key at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY_PAID=

# Optional: Anthropic Claude (for direct Claude API usage)
# ANTHROPIC_API_KEY=
